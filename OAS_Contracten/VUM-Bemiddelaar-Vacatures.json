            "type": "array"
          },
          "webadres": {
            "$ref": "#/components/schemas/Webadres"
          },
          "werkervaring": {
            "items": {
              "$ref": "#/components/schemas/Werkervaring"
            },
            "type": "array"
          },
          "werkgever": {
            "$ref": "#/components/schemas/MPWerkgever"
          },
          "werktijden": {
