  "components": {
    "headers": {
      "api_version": {
        "schema": {
          "enum": [
            "3.0.0"
          ],
          "type": "string"
        }
      },
      "vum_bericht_versie": {
        "schema": {
          "enum": [
            "3.0.0"
          ],
          "type": "string"
        }
      },
      "vum_from_party": {
        "schema": {
          "type": "string"
        }
      },
      "vum_to_party": {
        "schema": {
          "type": "string"
        }
      },
      "vum_via_party": {
        "schema": {
          "type": "string"
        }
      }
    },
    "parameters": {
      "api_version": {
        "in": "header",
        "name": "API-Version",
        "required": true,
        "schema": {
          "enum": [
            "3.0.0"
          ],
          "type": "string"
        }
      },
      "vum_bericht_versie": {
        "in": "header",
        "name": "X-VUM-berichtVersie",
        "required": true,
        "schema": {
          "enum": [
            "3.0.0"
          ],
          "type": "string"
        }
      },
      "vum_from_party": {
        "in": "header",
        "name": "X-VUM-fromParty",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "vum_to_party": {
        "in": "header",
        "name": "X-VUM-toParty",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "vum_via_party": {
        "in": "header",
        "name": "X-VUM-viaParty",
        "required": true,
        "schema": {
          "type": "string"
        }
      }
    },
    "requestBodies": {
      "VacatureMatchesRequest": {
        "content": {
          "application/json": {
            "schema": {
              "properties": {
                "vraagObject": {
                  "$ref": "#/components/schemas/MPVacature"
                }
              },
              "required": [
                "vraagObject"
              ],
              "type": "object"
            }
          }
        },
        "required": true
      }
    },
    "schemas": {
      "VacaturesMatchesResponse": {
        "required": [
          "maximumAantalResultatenBereikt",
          "vraagID",
          "matches"
        ],
        "type": "object",
        "properties": {
          "maximumAantalResultatenBereikt": {
            "type": "boolean",
            "description": "Geeft aan of bron meer matches zou kunnen leveren dan de teruggeleverde set. Bronnen mogen per zoekvraag een maximum aantal (standaard 100) resultaten leveren"
          },
          "vraagID": {
            "$ref": "#/components/schemas/VraagID"
          },
          "matches": {
            "$ref": "#/components/schemas/VacatureMatchingProfielen"
          }
        }
      },
      "VraagID": {
        "maxLength": 100,
        "type": "string"
      },
      "Adres": {
        "additionalProperties": false,
        "properties": {
          "postcode": {
            "$ref": "#/components/schemas/Postcode"
          },
          "straatnaam": {
            "$ref": "#/components/schemas/String24"
          },
          "huisnummer": {
            "$ref": "#/components/schemas/Integer5"
          },
          "huisnummertoevoeging": {
            "$ref": "#/components/schemas/String6"
          }
        },
        "required": [
          "postcode"
        ],
        "type": "object"
      },
      "ArbeidsVoorwaarden": {
        "additionalProperties": false,
        "properties": {
          "datumAanvangWerkzaamheden": {
            "$ref": "#/components/schemas/Date"
          },
          "datumEindeWerkzaamheden": {
            "$ref": "#/components/schemas/Date"
          },
          "omschrijvingArbeidsvoorwaarden": {
            "$ref": "#/components/schemas/String2000"
          },
          "salarisIndicatie": {
            "$ref": "#/components/schemas/String100"
          }
        },
        "type": "object"
      },
      "Beroep": {
        "additionalProperties": false,
        "properties": {
          "codeBeroepsnaam": {
            "$ref": "#/components/schemas/codeBeroepsnaam"
          }
        },
        "type": "object"
      },
      "Competentiebeheersing": {
        "additionalProperties": false,
        "properties": {
          "codeCompetentie": {
            "$ref": "#/components/schemas/StringHex10"
          },
          "codeCompetentieniveau": {
            "enum": [
              "L1",
              "L2",
              "L3",
              "L4"
            ],
            "type": "string"
          }
        },
        "type": "object"
      },
      "ContactpersoonAfdeling": {
        "additionalProperties": false,
        "properties": {
          "naamContactpersoonAfdeling": {
            "$ref": "#/components/schemas/String35"
          },
          "emailadres": {
            "items": {
              "$ref": "#/components/schemas/Emailadres"
            },
            "type": "array"
          },
          "telefoonnummer": {
            "items": {
              "$ref": "#/components/schemas/Telefoonnummer"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "Contractvorm": {
        "additionalProperties": false,
        "properties": {
          "codeTypeArbeidscontract": {
            "$ref": "#/components/schemas/codeTypeArbeidscontract"
          },
          "codeTypeOvereenkomst": {
            "enum": [
              "01",
              "02",
              "03",
              "04"
            ],
            "type": "string"
          }
        },
        "type": "object"
      },
      "Cursus": {
        "additionalProperties": false,
        "properties": {
          "indicatieCertificaat": {
            "$ref": "#/components/schemas/Indicatie"
          },
          "naamCursus": {
            "$ref": "#/components/schemas/String120"
          },
          "toelichtingCursus": {
            "$ref": "#/components/schemas/String2000"
          }
        },
        "type": "object"
      },
      "Date": {
        "format": "date",
        "type": "string"
      },
      "Emailadres": {
        "$ref": "#/components/schemas/String320"
      },
      "Error": {
        "properties": {
          "code": {
            "$ref": "#/components/schemas/StringCode"
          },
          "details": {
            "$ref": "#/components/schemas/String2000"
          },
          "message": {
            "$ref": "#/components/schemas/String500"
          }
        },
        "required": [
          "code",
          "message"
        ],
        "type": "object"
      },
      "Flexibiliteit": {
        "additionalProperties": false,
        "properties": {
          "codeRegiostraal": {
            "maximum": 9,
            "minimum": 1,
            "type": "integer"
          },
          "datumEindeBeschikbaarVoorWerk": {
            "$ref": "#/components/schemas/Date"
          },
          "indicatieOnregelmatigWerkOfPloegendienst": {
            "$ref": "#/components/schemas/Indicatie"
          }
        },
        "type": "object"
      },
      "IDVacature": {
        "$ref": "#/components/schemas/SafeIDString"
      },
      "Indicatie": {
        "enum": [
          0,
          1,
          2
        ],
        "type": "integer"
      },
      "Integer1000": {
        "maximum": 999,
        "minimum": 0,
        "type": "integer"
      },
      "Integer10AsString": {
        "example": "9999999999",
        "maxLength": 10,
        "pattern": "^[0-9]+$",
        "type": "string"
      },
      "Integer2": {
        "maximum": 99,
        "minimum": 0,
        "type": "integer"
      },
      "Integer5": {
        "maximum": 99999,
        "minimum": 0,
        "type": "integer"
      },
      "IntegerTaal": {
        "enum": [
          0,
          1,
          2,
          3,
          4,
          8
        ],
        "type": "integer"
      },
      "MPSollicitatiewijze": {
        "additionalProperties": false,
        "properties": {
          "codeSollicitatiewijze": {
            "enum": [
              "1",
              "2",
              "3",
              "4"
            ],
            "type": "string"
          }
        },
        "type": "object"
      },
      "MPVacature": {
        "properties": {
          "beroep.codeBeroepsnaam": {
            "$ref": "#/components/schemas/codeBeroepsnaam_selectie"
          },
          "codeWerkEnDenkniveauMinimaal": {
            "$ref": "#/components/schemas/codeWerkEnDenkNiveauMinimaal_selectie"
          },
          "rijbewijs": {
            "$ref": "#/components/schemas/rijbewijs_selectie"
          },
          "selectiegebied": {
            "$ref": "#/components/schemas/selectiegebied_selectie"
          },
          "taalbeheersing": {
            "$ref": "#/components/schemas/taalbeheersingen_selectie"
          },
          "werktijden.aantalWerkurenPerWeekMaximaal": {
            "$ref": "#/components/schemas/aantalWerkurenPerWeekMaximaal_selectie"
          },
          "werktijden.aantalWerkurenPerWeekMinimaal": {
            "$ref": "#/components/schemas/aantalWerkurenPerWeekMinimaal_selectie"
          }
        },
        "required": [
          "selectiegebied"
        ],
        "type": "object"
      },
      "MPVacatureMatch": {
        "additionalProperties": false,
        "properties": {
          "adres": {
            "$ref": "#/components/schemas/Adres"
          },
          "arbeidsVoorwaarden": {
            "$ref": "#/components/schemas/ArbeidsVoorwaarden"
          },
          "beroep": {
            "$ref": "#/components/schemas/Beroep"
          },
          "codeWerkEnDenkniveauMinimaal": {
            "enum": [
              "0",
              "1",
              "2",
              "3",
              "4",
              "5",
              "6",
              "7"
            ],
            "type": "string"
          },
          "competentiebeheersing": {
            "items": {
              "$ref": "#/components/schemas/Competentiebeheersing"
            },
            "type": "array"
          },
          "contractvorm": {
            "items": {
              "$ref": "#/components/schemas/Contractvorm"
            },
            "type": "array"
          },
          "cursus": {
            "items": {
              "$ref": "#/components/schemas/Cursus"
            },
            "type": "array"
          },
          "flexibiliteit": {
            "$ref": "#/components/schemas/Flexibiliteit"
          },
          "indicatieLdrRegistratie": {
            "enum": [
              1,
              2
            ],
            "type": "integer"
          },
          "naamVacature": {
            "$ref": "#/components/schemas/String120"
          },
          "omschrijvingArbeidsvoorwaarden": {
            "$ref": "#/components/schemas/String2000"
          },
          "omschrijvingVacature": {
            "$ref": "#/components/schemas/String2000"
          },
          "opleiding": {
            "items": {
              "$ref": "#/components/schemas/Opleiding"
            },
            "type": "array"
          },
          "rijbewijs": {
            "items": {
              "$ref": "#/components/schemas/Rijbewijs"
            },
            "type": "array"
          },
          "sector": {
            "$ref": "#/components/schemas/SectorBeroepsEnBedrijfsleven"
          },
          "sluitingsdatumVacature": {
            "$ref": "#/components/schemas/Date"
          },
          "sollicitatiewijze": {
            "items": {
              "$ref": "#/components/schemas/MPSollicitatiewijze"
            },
            "type": "array"
          },
          "taalbeheersing": {
            "items": {
              "$ref": "#/components/schemas/Taalbeheersing"
            },
            "type": "array"
          },
          "vervoermiddel": {
            "items": {
              "$ref": "#/components/schemas/Vervoermiddel"
